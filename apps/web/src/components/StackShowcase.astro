---
const groups = [
  {
    name: "Frontend",
    active: true,
    items: ["React 19", "React Router", "Vite", "Astro"],
  },
  {
    name: "Platform",
    items: ["Static hosting", "TypeScript", "GitHub Pages", "pnpm monorepo"],
  },
  {
    name: "Workflow",
    items: ["AI-assisted development", "Design systems", "Performance", "DX automation"],
  },
]
---

<div class="rounded-3xl border border-orange-100/90 bg-white/85 p-4 shadow-[0_18px_48px_-14px_rgba(251,146,60,0.14),0_8px_24px_-10px_rgba(167,139,250,0.07)] backdrop-blur-md">
  <div class="flex flex-wrap gap-2">
    {
      groups.map((group) => (
        <span
          class:list={[
            "inline-flex h-7 shrink-0 items-center justify-center rounded-[min(var(--radius-md),12px)] border px-2.5 text-[0.8rem] font-medium",
            group.active
              ? "border-transparent bg-gradient-to-br from-orange-600 via-orange-600 to-orange-700 text-white shadow-md shadow-orange-900/25"
              : "border-stone-200/90 bg-stone-50/90 text-stone-700",
          ]}
        >
          {group.name}
        </span>
      ))
    }
  </div>

  <div class="mt-6 grid gap-3 sm:grid-cols-2">
    {
      groups.flatMap((group) =>
        group.items.map((item) => (
          <div class="rounded-2xl border border-stone-200/70 bg-gradient-to-br from-white via-orange-50/30 to-violet-50/25 px-4 py-3 text-sm text-stone-700 shadow-sm shadow-orange-100/40">
            {item}
          </div>
        )),
      )
    }
  </div>
</div>
