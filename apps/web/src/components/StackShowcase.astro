---
const groups = [
	{
		name: "Frontend",
		items: ["React 19", "React Router", "Vite", "Astro"],
	},
	{
		name: "Platform",
		items: ["Static hosting", "TypeScript", "GitHub Pages", "pnpm monorepo"],
	},
	{
		name: "Workflow",
		items: ["AI-assisted development", "Design systems", "Performance", "DX automation"],
	},
] as const

const tabBase =
	"ssc-tab inline-flex h-7 shrink-0 cursor-pointer items-center justify-center rounded-[min(var(--radius-md),12px)] border px-2.5 text-[0.8rem] font-medium transition select-none border-stone-200/90 bg-stone-50/90 text-stone-700 hover:border-orange-200/70 hover:bg-orange-50/70"
---

<div
	class="ssc-root rounded-3xl border border-orange-100/90 bg-white/85 p-4 shadow-[0_18px_48px_-14px_rgba(251,146,60,0.14),0_8px_24px_-10px_rgba(167,139,250,0.07)] backdrop-blur-md"
>
	<div class="flex flex-wrap gap-2" role="tablist" aria-label="Stack categories">
		{
			groups.map((group, i) => (
				<label for={`ssc-tab-${i}`} role="tab" class:list={[tabBase]}>
					{group.name}
				</label>
			))
		}
	</div>

	<div class="ssc-inputs sr-only">
		{groups.map((_, i) => <input type="radio" name="ssc-stack-tab" id={`ssc-tab-${i}`} checked={i === 0} />)}
	</div>

	<div class="ssc-panels mt-6">
		{
			groups.map((group, i) => (
				<div
					class:list={["ssc-panel grid gap-3 sm:grid-cols-2", `ssc-panel-${i}`]}
					role="tabpanel"
					id={`ssc-panel-${i}`}
					aria-labelledby={`ssc-tab-${i}`}
				>
					{
						group.items.map((item) => (
							<div class="rounded-2xl border border-stone-200/70 bg-gradient-to-br from-white via-orange-50/30 to-violet-50/25 px-4 py-3 text-sm text-stone-700 shadow-sm shadow-orange-100/40">
								{item}
							</div>
						))
					}
				</div>
			))
		}
	</div>
</div>

<style is:global>
	/* Namespaced under .ssc-root so Astro does not rewrite #id ~ .sibling (which broke inlined CSS). */
	.ssc-root .ssc-panel {
		display: none;
	}

	.ssc-root:has(#ssc-tab-0:checked) .ssc-panel-0,
	.ssc-root:has(#ssc-tab-1:checked) .ssc-panel-1,
	.ssc-root:has(#ssc-tab-2:checked) .ssc-panel-2 {
		display: grid;
	}

	.ssc-root:has(#ssc-tab-0:checked) label[for="ssc-tab-0"],
	.ssc-root:has(#ssc-tab-1:checked) label[for="ssc-tab-1"],
	.ssc-root:has(#ssc-tab-2:checked) label[for="ssc-tab-2"] {
		border-color: transparent;
		background-image: linear-gradient(to bottom right, rgb(234 88 12), rgb(234 88 12), rgb(194 65 12));
		color: #fff;
		box-shadow:
			0 4px 6px -1px rgb(0 0 0 / 0.1),
			0 2px 4px -2px rgb(0 0 0 / 0.1),
			0 0 0 1px rgb(124 45 18 / 0.25);
	}
</style>
