---
const groups = [
  {
    name: "Frontend",
    items: ["React 19", "React Router", "Vite", "Astro"],
  },
  {
    name: "Platform",
    items: ["Static hosting", "TypeScript", "GitHub Pages", "pnpm monorepo"],
  },
  {
    name: "Workflow",
    items: ["AI-assisted development", "Design systems", "Performance", "DX automation"],
  },
] as const

const tabBase =
  "inline-flex h-7 shrink-0 cursor-pointer items-center justify-center rounded-[min(var(--radius-md),12px)] border px-2.5 text-[0.8rem] font-medium transition select-none border-stone-200/90 bg-stone-50/90 text-stone-700 hover:border-orange-200/70 hover:bg-orange-50/70"
---

<div class="stack-tabs rounded-3xl border border-orange-100/90 bg-white/85 p-4 shadow-[0_18px_48px_-14px_rgba(251,146,60,0.14),0_8px_24px_-10px_rgba(167,139,250,0.07)] backdrop-blur-md">
	{
		groups.map((_, i) => (
			<input
				type="radio"
				name="stack-showcase-tab"
				id={`stack-tab-${i}`}
				class="sr-only"
				checked={i === 0}
			/>
		))
	}

	<div class="flex flex-wrap gap-2" role="tablist" aria-label="Stack categories">
		{
			groups.map((group, i) => (
				<label
					for={`stack-tab-${i}`}
					role="tab"
					class:list={["stack-tab-label", tabBase]}
				>
					{group.name}
				</label>
			))
		}
	</div>

	<div class="stack-panels mt-6">
		{
			groups.map((group, i) => (
				<div
					class:list={["stack-panel grid gap-3 sm:grid-cols-2", `stack-panel-${i}`]}
					role="tabpanel"
					id={`stack-panel-${i}`}
					aria-labelledby={`stack-tab-${i}`}
				>
					{
						group.items.map((item) => (
							<div class="rounded-2xl border border-stone-200/70 bg-gradient-to-br from-white via-orange-50/30 to-violet-50/25 px-4 py-3 text-sm text-stone-700 shadow-sm shadow-orange-100/40">
								{item}
							</div>
						))
					}
				</div>
			))
		}
	</div>
</div>

<style>
	.stack-panel {
		display: none;
	}

	#stack-tab-0:checked ~ .stack-panels .stack-panel-0,
	#stack-tab-1:checked ~ .stack-panels .stack-panel-1,
	#stack-tab-2:checked ~ .stack-panels .stack-panel-2 {
		display: grid;
	}

	.stack-tabs:has(#stack-tab-0:checked) label[for="stack-tab-0"],
	.stack-tabs:has(#stack-tab-1:checked) label[for="stack-tab-1"],
	.stack-tabs:has(#stack-tab-2:checked) label[for="stack-tab-2"] {
		border-color: transparent;
		background-image: linear-gradient(to bottom right, rgb(234 88 12), rgb(234 88 12), rgb(194 65 12));
		color: #fff;
		box-shadow:
			0 4px 6px -1px rgb(0 0 0 / 0.1),
			0 2px 4px -2px rgb(0 0 0 / 0.1),
			0 0 0 1px rgb(124 45 18 / 0.25);
	}
</style>
