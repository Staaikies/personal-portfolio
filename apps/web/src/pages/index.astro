---
import { StackShowcase } from "@/components/StackShowcase"
import "../styles/global.css"

---

<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="A modern Astro portfolio built with React 19, Tailwind CSS v4, shadcn/ui, Hono, and Cloudflare Workers."
		/>
		<title>Skylar | Frontend Developer</title>
	</head>
	<body class="min-h-screen bg-slate-950 text-white antialiased">
		<main class="relative isolate overflow-hidden">
			<div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,rgba(34,211,238,0.24),transparent_34rem),radial-gradient(circle_at_80%_10%,rgba(168,85,247,0.18),transparent_30rem),linear-gradient(180deg,#020617_0%,#0f172a_100%)]"></div>
			<div class="absolute inset-0 -z-10 bg-[linear-gradient(rgba(255,255,255,0.035)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.035)_1px,transparent_1px)] bg-[size:72px_72px] [mask-image:linear-gradient(to_bottom,black,transparent_80%)]"></div>

			<section class="mx-auto grid min-h-screen max-w-6xl gap-12 px-6 py-20 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
				<div>
					<p class="mb-5 inline-flex rounded-full border border-cyan-300/20 bg-cyan-300/10 px-4 py-2 text-sm font-medium text-cyan-100">
						Astro marketing site on Cloudflare Workers
					</p>
					<h1 class="max-w-4xl text-5xl font-semibold tracking-tight text-balance sm:text-7xl">
						Frontend craft, full-stack systems, and AI-powered delivery.
					</h1>
					<p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300">
						I build fast, polished web experiences with TypeScript, React, Astro, Cloudflare Workers, and modern design systems. AI helps accelerate the loop; engineering judgment keeps the product sharp.
					</p>
					<div class="mt-8 flex flex-wrap gap-3">
						<a class="rounded-lg bg-cyan-300 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-200" href="#contact">
							Start a conversation
						</a>
						<a class="rounded-lg border border-white/15 bg-white/5 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10" href="/api/health">
							Check the Hono API
						</a>
					</div>
				</div>

				<div class="rounded-[2rem] border border-white/10 bg-white/[0.04] p-4 shadow-2xl shadow-cyan-950/30 backdrop-blur">
					<div class="grid aspect-square place-items-center rounded-[1.5rem] border border-dashed border-cyan-200/30 bg-slate-900/70 text-center">
						<div>
							<div class="mx-auto mb-4 grid size-24 place-items-center rounded-full bg-cyan-300/10 text-4xl">SK</div>
							<p class="font-medium text-slate-100">Profile image placeholder</p>
							<p class="mt-2 text-sm text-slate-400">Drop your portrait into `public/` and swap this card later.</p>
						</div>
					</div>
				</div>
			</section>

			<section class="mx-auto max-w-6xl px-6 pb-24">
				<div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
					<div>
						<p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-200">Stack</p>
						<h2 class="mt-3 text-3xl font-semibold tracking-tight">Modern TypeScript from UI to edge.</h2>
						<p class="mt-4 text-slate-300">
							This repo is set up as a pnpm monorepo with Astro, React 19 islands, Tailwind CSS v4, shadcn/ui Base + Nova, and a Hono API running inside the Cloudflare Worker.
						</p>
					</div>
					<StackShowcase client:load />
				</div>
			</section>

			<section id="contact" class="mx-auto max-w-6xl px-6 pb-24">
				<div class="rounded-3xl border border-white/10 bg-white/[0.04] p-8 backdrop-blur">
					<p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-200">Next</p>
					<h2 class="mt-3 text-3xl font-semibold tracking-tight">Ready for projects, case studies, and contact wiring.</h2>
					<p class="mt-4 max-w-3xl text-slate-300">
						Add real project cards, replace the profile placeholder, and connect `/api/contact` to your preferred email or storage provider when you are ready to publish.
					</p>
				</div>
			</section>
		</main>
	</body>
</html>
